# =============================================================================
# Wikforge - Environment Configuration
#
# 复制为 .env 后按部署环境调整。最少需要填的字段:
#   - POSTGRES_PASSWORD / MINIO_SECRET_KEY / JWT_SECRET_KEY  (强随机串)
#   - LITELLM_MASTER_KEY / LITELLM_SALT_KEY / LITELLM_UI_PASSWORD
#   - CPA_API_KEY / DASHSCOPE_API_KEY  (按需,影响 LLM/Embedding 能力)
#
# 一键生成所有密钥的命令见 docs/deploy.md。
# =============================================================================


# ===== Application =====
APP_NAME=Wikforge
APP_VERSION=0.1.0
DEBUG=false


# ===== API Server =====
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api


# ===== Frontend =====
FRONTEND_PORT=80
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000


# ===== PostgreSQL =====
# 注意:宿主机 5432 常被本地 PG / Navicat / 其它 Docker 占用。
# 默认改用 15432 避免冲突;若新机无冲突可改回 5432。容器内服务间通信走 5432 不变。
POSTGRES_HOST=postgres
POSTGRES_PORT=15432
POSTGRES_USER=wikforge
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=wikforge


# ===== Redis =====
# 同上,本地常已有 redis-server,默认走 16379。
REDIS_HOST=redis
REDIS_PORT=16379
REDIS_PASSWORD=
REDIS_DB=0


# ===== OpenSearch =====
# 2.12+ 要求强口令(大小写 + 数字 + 特殊符号)。
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=ChangeMe-In-Prod-123!
OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m


# ===== Qdrant =====
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=


# ===== MinIO =====
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-in-production
MINIO_BUCKET=wikforge-documents
MINIO_SECURE=false


# ===== JWT =====
# 生产请使用 32+ 字节随机串: openssl rand -hex 32
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7


# ===== OIDC (可选) =====
OIDC_DISCOVERY_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=


# ===== Initial Admin =====
# init_db 脚本会按此邮箱播种唯一管理员;require_admin 依赖按 email 匹配。
# 注意:邮箱不能用 .local 等保留域(pydantic EmailStr 会拒)。
INITIAL_ADMIN_EMAIL=admin@wikforge.com
INITIAL_ADMIN_PASSWORD=Admin@123
INITIAL_ADMIN_DISPLAY_NAME=系统管理员


# ===== LiteLLM Gateway =====
# wikforge 后端通过 LiteLLM SDK 访问独立部署的 LiteLLM Proxy 容器。
# 容器网络内走 http://litellm:4000;Admin UI 在 http://localhost:${LITELLM_PORT}/ui。
# LITELLM_API_KEY = Proxy Master Key,上游模型 Key 由 Proxy 内部持有。
LITELLM_API_BASE=http://litellm:4000
LITELLM_API_KEY=sk-change-me
LITELLM_MODEL=gpt-5.5
EMBEDDING_MODEL=text-embedding-v4

# ===== Reranker (检索精排) =====
# dashscope (默认): 调阿里 gte-rerank-v2 (中文最佳, 不占本地内存, ~0.0008元/次)
# local:            用本地 BAAI/bge-reranker-base (~440MB 内存常驻)
# disabled:         跳过 cross-encoder, 用 bigram fallback
RERANK_PROVIDER=dashscope
DASHSCOPE_RERANK_MODEL=gte-rerank-v2
# 多模态视觉模型: UniversalParser (L3 LLM 兜底) 调它处理扫描件 / 复杂版面
# 候选: qwen-vl-plus (DashScope, 性价比) / qwen-vl-max (DashScope, 能力强) /
#       gpt-4o (OpenAI 系) / claude-3-5-sonnet
LITELLM_VISION_MODEL=qwen-vl-plus

# PDF 解析模式: fitz (设计原意) | marker (~16GB 内存) | auto
# 默认 fitz: marker 不背 OCR 责任, 扫描件 / 复杂版面交给 L3 多模态 LLM
PDF_PARSER_MODE=fitz


# ===== LiteLLM Proxy 自身配置 =====
# 用 openssl rand -hex 24 生成 Master/Salt Key
LITELLM_PORT=4000
LITELLM_DB=litellm
LITELLM_MASTER_KEY=sk-change-me
LITELLM_SALT_KEY=sk-salt-change-me
LITELLM_UI_USERNAME=admin
LITELLM_UI_PASSWORD=change-me


# ===== 上游模型源凭证 (注入给 LiteLLM Proxy 容器) =====
# CPA: 提供 gpt-5.5 等 Chat 模型 (litellm/config.yaml 已默认配置)
# DashScope (百炼): 用于 text-embedding-v3 (1024 维)
# 注意: api_base 也走 env, 避免把私有网关域名硬编码到代码 / git 历史
CPA_API_BASE=https://api.openai.com/v1
CPA_API_KEY=
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=


# ===== Celery =====
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_TASK_TIMEOUT=60
CELERY_MAX_RETRIES=3


# ===== Quality Thresholds =====
QUALITY_FALLBACK_THRESHOLD=0.7
REVIEW_QUEUE_THRESHOLD=0.7
SIMILARITY_THRESHOLD=0.5


# ===== Universal Parser (LLM 兜底解析) =====
# 留空表示沿用 LITELLM_MODEL,由 LLMGateway 决定具体模型。
UNIVERSAL_PARSER_VISION_MODEL=qwen-vl-plus
UNIVERSAL_PARSER_TEXT_MODEL=
UNIVERSAL_PARSER_PAGE_DPI=150
UNIVERSAL_PARSER_LIBREOFFICE_TIMEOUT=60
UNIVERSAL_PARSER_MAX_RAW_TEXT_CHARS=3000


# ===== CORS =====
# JSON 数组字符串。注意 80 端口浏览器实际 Origin 不带端口(http://localhost),
# 与 http://localhost:80 是两个不同字符串,需分别列出。
CORS_ORIGINS=["http://localhost","http://localhost:80","http://localhost:3000","http://127.0.0.1","http://127.0.0.1:80","http://127.0.0.1:3000"]


# ===== Query Enhancement =====
QUERY_ENHANCEMENT_ENABLE_REWRITE=true
QUERY_ENHANCEMENT_ENABLE_HYDE=true
QUERY_ENHANCEMENT_ENABLE_DECOMPOSITION=true


# ===== Flower (Celery 监控面板) =====
# 浏览器访问 http://localhost:${FLOWER_PORT}, basic auth 登录
FLOWER_PORT=5555
FLOWER_USERNAME=admin
FLOWER_PASSWORD=change-me
